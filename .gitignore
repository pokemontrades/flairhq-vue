# Environment / secrets
.env
secrets.properties
flairhq-api/src/main/resources/secrets.properties

# SSL certs
certs/*.pem
certs/*.key

# API build output
flairhq-api/build/
flairhq-api/.gradle/

!flairhq-api/**/src/main/**/build/
!flairhq-api/**/src/test/**/build/

# Package Files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# Compiled class file
*.class


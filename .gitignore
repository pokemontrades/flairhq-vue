hs_err_pid*
replay_pid*

# Vue build output and local dependencies
flairhq-vue/node_modules/
flairhq-vue/dist/
flairhq-vue/.env

# Log file
*.log

# IDE
.idea/
*.iml
.vscode/

# OS
.DS_Store

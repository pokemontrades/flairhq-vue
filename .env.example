# Copy this file to .env and fill in all values before running docker compose

# GitHub username or org that owns the GHCR packages (e.g. your GitHub handle)
GHCR_OWNER=

# MongoDB — used by both the MongoDB container and the Spring Boot API
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=

# Public URL of the API (build-time arg baked into the Vue bundle)
VITE_API_BASE_URL=https://api.porygon.co

# Spring Boot runtime config
SPRING_PROFILES_ACTIVE=prod
FHQ_ENV=prod
SPRING_DATA_MONGODB_URI=mongodb://<user>:<password>@mongodb:27017/fapp?authSource=admin
APP_FRONTEND_URL=https://hq2.porygon.co

# Reddit OAuth2 app credentials
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=

# Reddit admin account refresh token (for setting flair / sending PMs)
REDDIT_ADMIN_REFRESH_TOKEN=

# Discord OAuth2 app + bot credentials
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_SERVER_ID=
DISCORD_AUTHENTICATED_ROLE_IDS=
DISCORD_BOT_TOKEN=

# Pre-shared key for service-to-service API access (leave blank to disable)
SERVICE_API_KEY=
